# Shared across every app on arpansarkar.org — same values everywhere.
# Never add VITE_SUPABASE_SERVICE_KEY or any other server-side Supabase key.
# RLS policies handle all access control instead.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay's key id is also needed on the frontend for checkout.js —
# expose it separately with the VITE_ prefix (still not a secret).
VITE_RAZORPAY_KEY_ID=
